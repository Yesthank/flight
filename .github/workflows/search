name: ✈️ 항공편 검색

on:
  # 수동 실행
  workflow_dispatch:
  
  # 자동 스케줄 (하루 2번: 한국시간 오전 9시, 오후 9시)
  schedule:
    - cron: '0 0 * * *'   # UTC 00:00 = KST 09:00
    - cron: '0 12 * * *'  # UTC 12:00 = KST 21:00

jobs:
  search:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: pip install amadeus

      - name: Run flight search
        env:
          AMADEUS_CLIENT_ID: ${{ secrets.AMADEUS_CLIENT_ID }}
          AMADEUS_CLIENT_SECRET: ${{ secrets.AMADEUS_CLIENT_SECRET }}
        run: python flight_search.py index.html

      - name: Deploy to GitHub Pages
        uses: peaceiris/actions-gh-pages@v4
        with:
          github_token: ${{ secrets.GITHUB_TOKEN }}
          publish_dir: ./
          publish_branch: main
          keep_files: true
